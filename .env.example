# NexFlow — Environment Variables

Copy this file to `.env` at the monorepo root and fill in your values.
Each service also has its own `.env` — the values below apply across services.

## ── Infrastructure ────────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres_pass@localhost:5432/nexflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=          # Uncomment if using Redis auth

## ── Auth Service (port 3001) ──────────────────────────────────────────────────

# Clerk — get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

## ── Web App (Next.js, port 3000) ─────────────────────────────────────────────

# Clerk (public — safe to expose)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# API Gateway URL (Nginx)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL (Realtime Service via Nginx proxy)
NEXT_PUBLIC_WS_URL=http://localhost:8080

## ── AI Orchestrator (FastAPI, port 8000) ─────────────────────────────────────

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME
# OPENAI_BASE_URL=          # Uncomment for Azure OpenAI or custom base URL
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

## ── Helpdesk Service SLA Thresholds (all values in minutes) ──────────────────

SLA_CRITICAL_RESPONSE_MIN=15
SLA_CRITICAL_RESOLVE_MIN=60
SLA_HIGH_RESPONSE_MIN=60
SLA_HIGH_RESOLVE_MIN=240
SLA_MEDIUM_RESPONSE_MIN=240
SLA_MEDIUM_RESOLVE_MIN=1440
SLA_LOW_RESPONSE_MIN=1440
SLA_LOW_RESOLVE_MIN=4320

## ── Notification Service (port 3004) ─────────────────────────────────────────

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
# SMTP_USER=               # Your SMTP username
# SMTP_PASS=               # Your SMTP password
SMTP_FROM=noreply@nexflow.local

## ── Realtime Service (port 4000) ─────────────────────────────────────────────

REALTIME_PORT=4000
CORS_ORIGIN=http://localhost:3000

## ── Integration Service (port 3005) ─────────────────────────────────────────

GITHUB_WEBHOOK_SECRET=dev_secret_replace_in_production

## ── Service Ports ────────────────────────────────────────────────────────────

AUTH_SERVICE_PORT=3001
WORK_ITEM_SERVICE_PORT=3002
HELPDESK_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
INTEGRATION_SERVICE_PORT=3005
AI_ORCHESTRATOR_PORT=8000
