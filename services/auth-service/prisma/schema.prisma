generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum rbac_role {
  SUPER_ADMIN
  PROJECT_ADMIN
  AGENT
  VIEWER
}

model user_roles {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String
  project_id String?    @db.Uuid
  role       rbac_role
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
}
