generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model tickets {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  subject             String
  description         String?
  contact_email       String
  priority            String?     @default("Medium") @db.VarChar(10)
  status              String?     @default("Open") @db.VarChar(20)
  assigned_agent_id   String?     @db.Uuid
  linked_work_item_id String?     @db.Uuid
  sla_response_at     DateTime?   @db.Timestamptz(6)
  sla_resolve_at      DateTime?   @db.Timestamptz(6)
  created_at          DateTime?   @default(now()) @db.Timestamptz(6)
  
  sla_logs            sla_logs[]
}

enum sla_event_type {
  RESPONSE_DUE
  RESOLVE_DUE
  BREACH
}

model sla_logs {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ticket_id         String?        @db.Uuid
  event_type        sla_event_type
  triggered_at      DateTime?      @default(now()) @db.Timestamptz(6)
  notified_agent_id String?        @db.Uuid
  created_at        DateTime?      @default(now()) @db.Timestamptz(6)
  
  tickets           tickets?       @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
