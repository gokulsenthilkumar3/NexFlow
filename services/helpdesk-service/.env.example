# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://nexflow:nexflow@localhost:5432/nexflow

# ─── Redis (shared with BullMQ) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Clerk ─────────────────────────────────────────────────
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ─── SMTP (Nodemailer) ─────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=helpdesk@example.com
SMTP_FROM_NAME=NexFlow Helpdesk

# ─── SLA Thresholds (in minutes) ───────────────────────────
# CRITICAL
SLA_CRITICAL_RESPONSE_MIN=60
SLA_CRITICAL_RESOLVE_MIN=240

# HIGH
SLA_HIGH_RESPONSE_MIN=240
SLA_HIGH_RESOLVE_MIN=480

# MEDIUM
SLA_MEDIUM_RESPONSE_MIN=720
SLA_MEDIUM_RESOLVE_MIN=1440

# LOW
SLA_LOW_RESPONSE_MIN=1440
SLA_LOW_RESOLVE_MIN=2880
