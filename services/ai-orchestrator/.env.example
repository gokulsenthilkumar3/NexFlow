# AI Orchestrator — Environment Variables
# Copy this file to .env and fill in real values

# ── FastAPI server ──────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional: set if Redis requires a password
# REDIS_PASSWORD=

# ── Redis Streams ──────────────────────────────────────────────────────────
# Stream this service reads work-item triage events from
TRIAGE_STREAM=events:triage
# Consumer group name (created automatically on first run)
TRIAGE_CONSUMER_GROUP=ai-orchestrator-group
# This instance's consumer name (useful for horizontal scaling)
TRIAGE_CONSUMER_NAME=ai-orchestrator-1
# Stream this service publishes AI results to (consumed by work-item-service)
UPDATES_STREAM=events:updates
# Stream this service publishes ticket breach summaries to
BREACH_STREAM=events:breach

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# Model to use for all LLM calls (override to use gpt-4o, gpt-3.5-turbo, etc.)
AI_MODEL=gpt-4o-mini
# Max tokens for triage output
AI_MAX_TOKENS=512
# Temperature for generation (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.3
