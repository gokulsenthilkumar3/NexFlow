generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum asset_status {
  Available
  Assigned
  Maintenance
  Retired
}

enum asset_category {
  Laptop
  Monitor
  Phone
  License
  Peripheral
  Other
}

enum audit_action {
  CREATED
  ASSIGNED
  RETURNED
  MAINTENANCE
  RETIRED
  LINKED_TICKET
  UPDATED
}

// ── Models ────────────────────────────────────────────────────────────────────

model assets {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  serial_number    String             @unique @db.VarChar(100)
  category         asset_category
  status           asset_status       @default(Available)
  purchase_date    DateTime?          @db.Date
  warranty_expiry  DateTime?          @db.Date
  purchase_cost    Decimal?           @db.Decimal(10, 2)
  notes            String?
  qr_code_url      String?            // base64 data URL
  linked_ticket_id String?            @db.Uuid
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @updatedAt @db.Timestamptz(6)

  assignments      asset_assignments[]
  audit_logs       asset_audit_logs[]
}

model asset_assignments {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  asset_id     String    @db.Uuid
  user_id      String
  assigned_at  DateTime  @default(now()) @db.Timestamptz(6)
  returned_at  DateTime? @db.Timestamptz(6)
  assigned_by  String
  notes        String?

  asset        assets    @relation(fields: [asset_id], references: [id], onDelete: Cascade)
}

model asset_audit_logs {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  asset_id     String       @db.Uuid
  action       audit_action
  performed_by String
  metadata     Json?
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)

  asset        assets       @relation(fields: [asset_id], references: [id], onDelete: Cascade)
}
